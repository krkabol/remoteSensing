{
    "name": "symfony/github-app",
    "description": "Symfony 8 application with GitHub OAuth authentication",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^3",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.3",
        "league/oauth2-client": "^2.7",
        "symfony/asset": "^8",
        "symfony/console": "^8",
        "symfony/dotenv": "^8",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "^8",
        "symfony/http-client": "^8",
        "symfony/monolog-bundle": "^4",
        "symfony/runtime": "^8",
        "symfony/security-bundle": "^8",
        "symfony/twig-bundle": "^8",
        "symfony/validator": "^8",
        "symfony/yaml": "^8"
    },
    "require-dev": {
        "symfony/debug-bundle": "^8",
        "symfony/maker-bundle": "^1.61",
        "symfony/stopwatch": "^8",
        "symfony/web-profiler-bundle": "^8"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8"
        }
    }
}
