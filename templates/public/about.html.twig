{% extends 'base.html.twig' %}

{% block title %}About - Remote Sensing{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="display-5 fw-bold mb-4">About Remote Sensing</h1>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Our Mission</h5>
                    <p class="card-text">
                        We provide a comprehensive platform for remote sensing data storage,
                        enabling researchers and scientists to access, process, and share
                        data collected remotely.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Features</h5>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle text-success"></i> Multi-source data storage</li>
                        <li><i class="bi bi-check-circle text-success"></i> Collaborative research environment</li>
                        <li><i class="bi bi-check-circle text-success"></i> GitHub integration for developer authentication</li>
                        <li><i class="bi bi-check-circle text-success"></i> Secure internal workspace</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">GitHub Integration</h5>
                    <p class="card-text">
                        We use GitHub for authentication.
                        GitHub provides a secure and convenient way to access our platform
                        using your existing developer account.
                    </p>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="{{ path('app_public_index') }}" class="btn btn-primary">
                    <i class="bi bi-arrow-left"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
