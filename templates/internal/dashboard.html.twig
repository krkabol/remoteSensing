{% extends 'internal/base.html.twig' %}

{% block title %}Dashboard - Remote Sensing{% endblock %}

{% block main_class %}container-fluid py-4{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <h1 class="mb-4">Analytics Dashboard</h1>
        
        <div class="alert alert-warning">
            <i class="bi bi-cone-striped"></i> 
            This is a placeholder dashboard. Extend this application by adding your remote sensing features.
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-layers display-4 text-primary mb-3"></i>
                        <h5 class="card-title">Data Layers</h5>
                        <p class="card-text">Manage your satellite data layers and imagery sources.</p>
                        <button class="btn btn-primary" disabled>
                            <i class="bi bi-plus"></i> Add Layer
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-bar-chart display-4 text-success mb-3"></i>
                        <h5 class="card-title">Analysis</h5>
                        <p class="card-text">Run analysis on your remote sensing data.</p>
                        <button class="btn btn-success" disabled>
                            <i class="bi bi-play"></i> Start Analysis
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-download display-4 text-info mb-3"></i>
                        <h5 class="card-title">Exports</h5>
                        <p class="card-text">Download processed data and generate reports.</p>
                        <button class="btn btn-info text-white" disabled>
                            <i class="bi bi-file-earmark"></i> Export
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <i class="bi bi-clock-history"></i> Recent Activity
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-0">No recent activity to display.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
