{% extends 'base.html.twig' %}

{% block title %}Dashboard - Remote Sensing{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-3 text-muted">
                    <span>Navigation</span>
                </h6>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_internal_index') }}">
                            <i class="bi bi-house"></i> Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_internal_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Dashboard</h1>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="alert alert-warning">
                        <i class="bi bi-cone-striped"></i> 
                        This is a placeholder dashboard. Extend this application by adding your remote sensing features.
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-layers display-4 text-primary mb-3"></i>
                            <h5 class="card-title">Data Layers</h5>
                            <p class="card-text">Manage your satellite data layers and imagery sources.</p>
                            <button class="btn btn-primary" disabled>
                                <i class="bi bi-plus"></i> Add Layer
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-bar-chart display-4 text-success mb-3"></i>
                            <h5 class="card-title">Analysis</h5>
                            <p class="card-text">Run analysis on your remote sensing data.</p>
                            <button class="btn btn-success" disabled>
                                <i class="bi bi-play"></i> Start Analysis
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-download display-4 text-info mb-3"></i>
                            <h5 class="card-title">Exports</h5>
                            <p class="card-text">Download processed data and generate reports.</p>
                            <button class="btn btn-info text-white" disabled>
                                <i class="bi bi-file-earmark"></i> Export
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <i class="bi bi-clock-history"></i> Recent Activity
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-0">No recent activity to display.</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}