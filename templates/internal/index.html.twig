{% extends 'internal/base.html.twig' %}

{% block title %}Internal - Remote Sensing{% endblock %}

{% block main_class %}container-fluid py-4{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <h1 class="mb-4">Internal Dashboard</h1>
        
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> 
            Welcome to the internal section! This area is only accessible to authenticated users.
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <i class="bi bi-person-check"></i> Authentication Status
                    </div>
                    <div class="card-body">
                        <p><strong>GitHub ID:</strong> {{ app.user.githubId }}</p>
                        <p><strong>Name:</strong> {{ app.user.name ?: 'Not provided' }}</p>
                        <p><strong>Email:</strong> {{ app.user.email ?: 'Not provided' }}</p>
                        <p><strong>Member since:</strong> {{ app.user.createdAt|date('Y-m-d H:i') }}</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-shield-check"></i> Security
                    </div>
                    <div class="card-body">
                        <p class="mb-2">You are securely logged in via GitHub OAuth.</p>
                        <p class="mb-0 text-muted small">
                            <i class="bi bi-lock"></i> This section requires authentication.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <i class="bi bi-grid"></i> Quick Actions
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <a href="{{ path('app_internal_dashboard') }}" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-speedometer2"></i> Analytics
                                </a>
                            </div>
                            <div class="col-md-4 mb-3">
                                <a href="{{ path('app_public_index') }}" class="btn btn-outline-secondary w-100">
                                    <i class="bi bi-globe"></i> Public Section
                                </a>
                            </div>
                            <div class="col-md-4 mb-3">
                                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
