{% extends 'base.html.twig' %}

{% block title %}Login - Remote Sensing{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </h2>
                    
                    {% if error %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endif %}

                    {% if app.session.flashbag.peek('auth_error')|length > 0 %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle"></i> {{ app.session.flashbag.get('auth_error')[0] }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endif %}

                    <div class="text-center mb-4">
                        <p class="text-muted">
                            Sign in with your GitHub account to access the internal section.
                        </p>
                    </div>

                    <div class="d-grid">
                        <a href="{{ path('app_auth_github') }}" class="btn btn-dark btn-lg">
                            <i class="bi bi-github" style="margin-right: 8px;"></i>
                            Login with GitHub
                        </a>
                    </div>

                    <hr class="my-4">

                    <div class="text-center">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i> 
                            GitHub is a platform for developers. 
                            <a href="https://github.com/signup" target="_blank">Create a GitHub account</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}